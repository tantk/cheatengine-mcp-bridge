        <CheatEntry>
          <ID>60</ID>
          <Description>"--- Battle ---"</Description>
          <GroupHeader>1</GroupHeader>
          <Color>008000</Color>
          <CheatEntries>
            <CheatEntry>
              <ID>1000</ID>
              <Description>"One-Hit KO (set all enemies to 1 HP)"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
LaunchMonoDataCollector()
local bcId = mono_findClass("", "BattleController")
if not bcId or bcId == 0 then error("BattleController class not found") end
local fields = mono_class_enumFields(bcId)
local bcInstance = nil
for _, f in ipairs(fields) do
  if f.name == "_instance" then
    bcInstance = mono_class_getStaticFieldValue(bcId, f.field)
    break
  end
end
if not bcInstance or bcInstance == 0 then error("Not in battle (BattleController._instance null)") end
local playerUnit = readQword(bcInstance + 0x1A8)
if not playerUnit or playerUnit == 0 then error("Player unit not found") end
local pTeam = readQword(playerUnit + 0x58)
if not pTeam or pTeam == 0 then error("Player team null") end
local playerTeamID = readInteger(pTeam + 0x10)
local teams = readQword(bcInstance + 0x70)
if not teams or teams == 0 then error("Teams list null") end
local teamItems = readQword(teams + 0x10)
if not teamItems or teamItems == 0 then error("Team items null") end
local teamCount = readInteger(teams + 0x18)
local killed = 0
for t = 0, teamCount - 1 do
  local team = readQword(teamItems + 0x20 + t * 8)
  if team and team ~= 0 then
    local teamID = readInteger(team + 0x10)
    if teamID ~= playerTeamID then
      local units = readQword(team + 0x18)
      if units and units ~= 0 then
        local unitCount = readInteger(units + 0x18)
        local unitItems = readQword(units + 0x10)
        if unitItems and unitItems ~= 0 then
          for u = 0, unitCount - 1 do
            local unit = readQword(unitItems + 0x20 + u * 8)
            if unit and unit ~= 0 then
              local heroData = readQword(unit + 0x40)
              if heroData and heroData ~= 0 then
                local hp = readFloat(heroData + 0x178)
                if hp > 0 then
                  writeFloat(heroData + 0x178, 1.0)
                  killed = killed + 1
                end
              end
            end
          end
        end
      end
    end
  end
end
print(string.format("[Battle] Set %d enemies to 1 HP", killed))
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
print("[Battle] (toggle again to use in next fight)")
{$asm}
              </AssemblerScript>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>

        <CheatEntry>
          <ID>40</ID>
          <Description>"--- Stats ---"</Description>
          <GroupHeader>1</GroupHeader>
          <Color>008000</Color>
          <CheatEntries>
            <CheatEntry>
              <ID>200</ID>
              <Description>"Set Stat Caps (all skills/attributes)"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
local hero, err = _lyGetHero()
if not hero then error(err) end

local input = InputQuery("Stat Cap Boost", "Enter new cap value for all skills/attributes:", "99")
if input then
  local capValue = tonumber(input) or 99.0
  local lists = {0x130, 0x148, 0x160}
  local total = 0
  for _, offset in ipairs(lists) do
    local listPtr = readQword(hero + offset)
    if listPtr and listPtr ~= 0 then
      local count = readInteger(listPtr + 0x18)
      local items = readQword(listPtr + 0x10)
      if items and items ~= 0 and count then
        for j = 0, count - 1 do
          local cur = readFloat(items + 0x20 + j * 4)
          if cur and capValue > cur then
            writeFloat(items + 0x20 + j * 4, capValue)
            total = total + 1
          end
        end
      end
    end
  end
  print(string.format("[StatCap] Boosted %d stats to %.0f", total, capValue))
end
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
print("[StatCap] (values remain as set)")
{$asm}
              </AssemblerScript>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>


        <CheatEntry>
