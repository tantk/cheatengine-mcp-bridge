<?xml version="1.0" encoding="utf-8"?>
<CheatTable>
  <CheatEntries>
    <CheatEntry>
      <ID>0</ID>
      <Description>"LongYinLiZhiZhuan (v1.0) - Attach to game first, then enable cheats"</Description>
      <GroupHeader>1</GroupHeader>
      <Color>FF0000</Color>
      <CheatEntries>

        <CheatEntry>
          <ID>10</ID>
          <Description>"--- Resources ---"</Description>
          <GroupHeader>1</GroupHeader>
          <Color>008000</Color>
          <CheatEntries>
            <CheatEntry>
              <ID>700</ID>
              <Description>"Set Money (Silver)"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
LaunchMonoDataCollector()
local gcId = mono_findClass("", "GameController")
local fields = mono_class_enumFields(gcId)
local gcInstance = nil
for _, f in ipairs(fields) do
  if f.name == "_instance" then
    gcInstance = mono_class_getStaticFieldValue(gcId, f.field)
    break
  end
end
if not gcInstance or gcInstance == 0 then error("GameController not found") end
local worldData = readQword(gcInstance + 0x20)
local herosList = readQword(worldData + 0x50)
local itemsPtr = readQword(herosList + 0x10)
local hero = readQword(itemsPtr + 0x20)
if not hero or hero == 0 then error("Hero not found") end
local itemListData = readQword(hero + 0x220)
if not itemListData or itemListData == 0 then error("ItemListData not found") end
local cur = readInteger(itemListData + 0x18)
local input = InputQuery("Set Money", "Current: " .. cur .. " silver. Enter new value:", "9999")
if input then
  local val = tonumber(input) or 9999
  writeInteger(itemListData + 0x18, math.floor(val))
  print(string.format("[Money] Set to %d silver", val))
end
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
print("[Money] (value remains as set)")
{$asm}
              </AssemblerScript>
            </CheatEntry>
            <CheatEntry>
              <ID>600</ID>
              <Description>"Set Sect Currency (forceContribution)"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
LaunchMonoDataCollector()
local gcId = mono_findClass("", "GameController")
local fields = mono_class_enumFields(gcId)
local gcInstance = nil
for _, f in ipairs(fields) do
  if f.name == "_instance" then
    gcInstance = mono_class_getStaticFieldValue(gcId, f.field)
    break
  end
end
if not gcInstance or gcInstance == 0 then error("GameController not found") end
local worldData = readQword(gcInstance + 0x20)
local herosList = readQword(worldData + 0x50)
local itemsPtr = readQword(herosList + 0x10)
local hero = readQword(itemsPtr + 0x20)
if not hero or hero == 0 then error("Hero not found") end
local cur = readFloat(hero + 0x1C0)
local input = InputQuery("Sect Currency", "Current: " .. string.format("%.1f", cur) .. ". Enter new value:", "1000")
if input then
  local val = tonumber(input) or 1000
  writeFloat(hero + 0x1C0, val * 1.0)
  print(string.format("[SectCurrency] Set to %.0f", val))
end
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
print("[SectCurrency] (value remains as set)")
{$asm}
              </AssemblerScript>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>

        <CheatEntry>
          <ID>20</ID>
          <Description>"--- Talents (TianFu) ---"</Description>
          <GroupHeader>1</GroupHeader>
          <Color>008000</Color>
          <CheatEntries>
            <CheatEntry>
              <ID>300</ID>
              <Description>"Max Talent Slots (9 -> 99)"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
LaunchMonoDataCollector()
local classId = mono_findClass("", "HeroData")
if not classId or classId == 0 then error("HeroData not found") end
local methods = mono_class_enumMethods(classId)
local targetAddr = nil
for _, m in ipairs(methods) do
  if m.name == "GetMaxTagNum" then
    targetAddr = mono_compile_method(m.method)
    break
  end
end
if not targetAddr or targetAddr == 0 then error("GetMaxTagNum not found") end
for offset = 0, 511 do
  local b1 = readBytes(targetAddr + offset, 1)
  local b2 = readBytes(targetAddr + offset + 1, 1)
  local b3 = readBytes(targetAddr + offset + 2, 1)
  if b1 == 0x83 and b2 == 0xC0 and (b3 == 0x09 or b3 == 0x63) then
    local b4 = readBytes(targetAddr + offset + 3, 1)
    local b5 = readBytes(targetAddr + offset + 4, 1)
    if b4 == 0x48 and b5 == 0x83 then
      talentCapPatchAddr = targetAddr + offset + 2
      talentCapOrigByte = 0x09
      if b3 == 0x63 then
        print(string.format("[TalentCap] Already patched at 0x%X", targetAddr + offset))
      else
        writeBytes(talentCapPatchAddr, 0x63)
        print(string.format("[TalentCap] Patched at 0x%X (max: 99)", targetAddr + offset))
      end
      return
    end
  end
end
error("Patch pattern not found")
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
if talentCapPatchAddr and talentCapOrigByte then
  writeBytes(talentCapPatchAddr, talentCapOrigByte)
  print("[TalentCap] Restored original cap (9)")
  talentCapPatchAddr = nil
  talentCapOrigByte = nil
end
{$asm}
              </AssemblerScript>
            </CheatEntry>
            <CheatEntry>
              <ID>500</ID>
