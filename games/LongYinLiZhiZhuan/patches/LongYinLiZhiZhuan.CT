if input then
  local val = tonumber(input) or 1000
  writeFloat(hero + 0x1C4, val * 1.0)
  writeFloat(hero + 0x1C8, 0.0)
  print(string.format("[Fame] Set fame=%.0f badFame=0", val))
end
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
print("[Fame] (values remain as set)")
{$asm}
              </AssemblerScript>
            </CheatEntry>
          </CheatEntries>
        </CheatEntry>

        <CheatEntry>
          <ID>60</ID>
          <Description>"--- Battle ---"</Description>
          <GroupHeader>1</GroupHeader>
          <Color>008000</Color>
          <CheatEntries>
            <CheatEntry>
              <ID>1000</ID>
              <Description>"One-Hit KO (set all enemies to 1 HP)"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
LaunchMonoDataCollector()
local bcId = mono_findClass("", "BattleController")
local fields = mono_class_enumFields(bcId)
local bcInstance = nil
for _, f in ipairs(fields) do
  if f.name == "_instance" then
    bcInstance = mono_class_getStaticFieldValue(bcId, f.field)
    break
  end
end
if not bcInstance or bcInstance == 0 then error("Not in battle") end
local playerUnit = readQword(bcInstance + 0x1A8)
if not playerUnit or playerUnit == 0 then error("Player unit not found") end
local pTeam = readQword(playerUnit + 0x58)
local playerTeamID = readInteger(pTeam + 0x10)
local teams = readQword(bcInstance + 0x70)
local teamItems = readQword(teams + 0x10)
local teamCount = readInteger(teams + 0x18)
local killed = 0
for t = 0, teamCount - 1 do
  local team = readQword(teamItems + 0x20 + t * 8)
  local teamID = readInteger(team + 0x10)
  if teamID ~= playerTeamID then
    local units = readQword(team + 0x18)
    local unitCount = readInteger(units + 0x18)
    local unitItems = readQword(units + 0x10)
    for u = 0, unitCount - 1 do
      local unit = readQword(unitItems + 0x20 + u * 8)
      if unit and unit ~= 0 then
        local heroData = readQword(unit + 0x40)
        local hp = readFloat(heroData + 0x178)
        if hp > 0 then
          writeFloat(heroData + 0x178, 1.0)
          killed = killed + 1
        end
      end
    end
  end
end
print(string.format("[Battle] Set %d enemies to 1 HP", killed))
{$asm}

