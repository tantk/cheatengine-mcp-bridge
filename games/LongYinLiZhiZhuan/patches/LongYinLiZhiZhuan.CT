        <CheatEntry>
          <ID>30</ID>
          <Description>"--- Skills ---"</Description>
          <GroupHeader>1</GroupHeader>
          <Color>008000</Color>
          <CheatEntries>
            <CheatEntry>
              <ID>800</ID>
              <Description>"Max Skill Learn Limits (all tiers -> 99)"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
LaunchMonoDataCollector()
local gdId = mono_findClass("", "GlobalData")
if not gdId or gdId == 0 then error("GlobalData not found") end
local fields = mono_class_enumFields(gdId)
local maxSkillNumField = nil
for _, f in ipairs(fields) do
  if f.name == "MaxSkillNum" then maxSkillNumField = f break end
end
if not maxSkillNumField then error("MaxSkillNum not found") end
local listPtr = mono_class_getStaticFieldValue(gdId, maxSkillNumField.field)
if not listPtr or listPtr == 0 then error("MaxSkillNum list not found") end
local count = readInteger(listPtr + 0x18)
local items = readQword(listPtr + 0x10)
skillLimitOrig = {}
for i = 0, count - 1 do
  skillLimitOrig[i] = readFloat(items + 0x20 + i * 4)
  writeFloat(items + 0x20 + i * 4, 99.0)
end
print(string.format("[SkillLimit] All %d tiers set to 99", count))
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
if skillLimitOrig then
  local gdId = mono_findClass("", "GlobalData")
  local fields = mono_class_enumFields(gdId)
  for _, f in ipairs(fields) do
    if f.name == "MaxSkillNum" then
      local listPtr = mono_class_getStaticFieldValue(gdId, f.field)
      local items = readQword(listPtr + 0x10)
      for i, v in pairs(skillLimitOrig) do
        writeFloat(items + 0x20 + i * 4, v)
      end
      break
    end
  end
  print("[SkillLimit] Restored original limits")
  skillLimitOrig = nil
end
{$asm}
              </AssemblerScript>
            </CheatEntry>
            <CheatEntry>
              <ID>400</ID>
              <Description>"WuXueTianCai Buff - Combat Skill EXP Rate (default 30%)"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
LaunchMonoDataCollector()
local gdcId = mono_findClass("", "GameDataController")
if not gdcId or gdcId == 0 then error("GameDataController not found") end
local fields = mono_class_enumFields(gdcId)
local gdcInstance = nil
for _, f in ipairs(fields) do
  if f.name == "_instance" then
    gdcInstance = mono_class_getStaticFieldValue(gdcId, f.field)
    break
  end
end
if not gdcInstance or gdcInstance == 0 then error("GDC instance not found") end
local gdcAllFields = mono_class_enumFields(gdcId)
local tagBaseOffset = 0x198
for _, gf in ipairs(gdcAllFields) do
  if gf.name == "heroTagDataBase" then tagBaseOffset = gf.offset break end
end
local tagDataBase = readQword(gdcInstance + tagBaseOffset)
local tagItems = readQword(tagDataBase + 0x10)
local tag222 = readQword(tagItems + 0x20 + 222 * 8)
local buffData = readQword(tag222 + 0x50)
local dict = readQword(buffData + 0x10)
local entries = readQword(dict + 0x18)
local count = readInteger(dict + 0x20)
talentBuffAddrs = {}
for i = 0, count - 1 do
  local base = entries + 0x20 + i * 16
  local key = readInteger(base + 8)
  if key == 176 then talentBuffAddrs.fight = base + 12 end
  if key == 177 then talentBuffAddrs.book = base + 12 end
end
local curFight = readFloat(talentBuffAddrs.fight or 0) or 0
local curBook = readFloat(talentBuffAddrs.book or 0) or 0
talentBuffOrigFight = curFight
talentBuffOrigBook = curBook
local input = InputQuery("WuXueTianCai Buff", "Current: FightExp=" .. string.format("%.0f%%", curFight*100) .. " BookExp=" .. string.format("%.0f%%", curBook*100) .. ". Enter new % (e.g. 300 for 300%):", "300")
if input then
  local pct = tonumber(input) or 300
  local newVal = pct / 100.0
  if talentBuffAddrs.fight then writeFloat(talentBuffAddrs.fight, newVal) end
  if talentBuffAddrs.book then writeFloat(talentBuffAddrs.book, newVal) end
  print(string.format("[WuXueTianCai] Set fight=%.0f%% book=%.0f%%", pct, pct))
end
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
if talentBuffAddrs then
  if talentBuffAddrs.fight and talentBuffOrigFight then writeFloat(talentBuffAddrs.fight, talentBuffOrigFight) end
  if talentBuffAddrs.book and talentBuffOrigBook then writeFloat(talentBuffAddrs.book, talentBuffOrigBook) end
  print("[WuXueTianCai] Restored original values")
  talentBuffAddrs = nil
end
{$asm}
              </AssemblerScript>
            </CheatEntry>
