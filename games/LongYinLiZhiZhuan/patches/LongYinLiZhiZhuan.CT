              <ID>1300</ID>
              <Description>"Max Rarity All Inventory Items"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
local function getHero()
  LaunchMonoDataCollector()
  local gcId = mono_findClass("", "GameController")
  if not gcId or gcId == 0 then return nil, "GameController class not found" end
  local fields = mono_class_enumFields(gcId)
  local inst
  for _, f in ipairs(fields) do if f.name == "_instance" then inst = mono_class_getStaticFieldValue(gcId, f.field) break end end
  if not inst or inst == 0 then return nil, "GameController not found (game not loaded?)" end
  local wd = readQword(inst + 0x20); if not wd or wd == 0 then return nil, "WorldData null" end
  local hl = readQword(wd + 0x50);  if not hl or hl == 0 then return nil, "HerosList null" end
  local ip = readQword(hl + 0x10);  if not ip or ip == 0 then return nil, "HerosList items null" end
  local h = readQword(ip + 0x20);   if not h or h == 0 then return nil, "Hero not found" end
  return h, inst
end
local hero, err = getHero()
if not hero then error(err) end
local itemListData = readQword(hero + 0x220)
if not itemListData or itemListData == 0 then error("ItemListData not found") end
local allItem = readQword(itemListData + 0x28)
if not allItem or allItem == 0 then error("allItem list null") end
local itemCount = readInteger(allItem + 0x18)
local itemArr = readQword(allItem + 0x10)
if not itemArr or itemArr == 0 then error("Item array null") end
local changed = 0
for i = 0, itemCount - 1 do
  local item = readQword(itemArr + 0x20 + i * 8)
  if item and item ~= 0 then
    local cur = readInteger(item + 0x40)
    if cur ~= 5 then
      writeInteger(item + 0x40, 5)
      changed = changed + 1
    end
  end
end
print(string.format("[Rarity] Set %d/%d items to max rarity (5)", changed, itemCount))
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
print("[Rarity] (values remain as set)")
{$asm}
