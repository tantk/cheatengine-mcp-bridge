            <CheatEntry>
              <ID>400</ID>
              <Description>"WuXueTianCai Buff - Combat Skill EXP Rate (default 30%)"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
LaunchMonoDataCollector()
local gdcId = mono_findClass("", "GameDataController")
if not gdcId or gdcId == 0 then error("GameDataController not found") end
local fields = mono_class_enumFields(gdcId)
local gdcInstance = nil
for _, f in ipairs(fields) do
  if f.name == "_instance" then
    gdcInstance = mono_class_getStaticFieldValue(gdcId, f.field)
    break
  end
end
if not gdcInstance or gdcInstance == 0 then error("GDC instance not found") end
local tagBaseOffset = 0x198
for _, gf in ipairs(fields) do
  if gf.name == "heroTagDataBase" then tagBaseOffset = gf.offset break end
end
local tagDataBase = readQword(gdcInstance + tagBaseOffset)
if not tagDataBase or tagDataBase == 0 then error("heroTagDataBase null (talent data not loaded?)") end
local tagItems = readQword(tagDataBase + 0x10)
if not tagItems or tagItems == 0 then error("tagDataBase items null") end
local tag222 = readQword(tagItems + 0x20 + 222 * 8)
if not tag222 or tag222 == 0 then error("Tag 222 (WuXueTianCai) not found in DB") end
local buffData = readQword(tag222 + 0x50)
if not buffData or buffData == 0 then error("Tag 222 buffData null") end
local dict = readQword(buffData + 0x10)
if not dict or dict == 0 then error("buffData dict null") end
local entries = readQword(dict + 0x18)
if not entries or entries == 0 then error("dict entries null") end
local count = readInteger(dict + 0x20)
_talentBuffAddrs = {}
for i = 0, count - 1 do
  local base = entries + 0x20 + i * 16
  local key = readInteger(base + 8)
  if key == 176 then _talentBuffAddrs.fight = base + 12 end
  if key == 177 then _talentBuffAddrs.book = base + 12 end
end
local curFight = _talentBuffAddrs.fight and readFloat(_talentBuffAddrs.fight) or 0
local curBook = _talentBuffAddrs.book and readFloat(_talentBuffAddrs.book) or 0
_talentBuffOrigFight = curFight
_talentBuffOrigBook = curBook
local input = InputQuery("WuXueTianCai Buff", "Current: FightExp=" .. string.format("%.0f%%", curFight*100) .. " BookExp=" .. string.format("%.0f%%", curBook*100) .. ". Enter new % (e.g. 300 for 300%):", "300")
if input then
  local pct = tonumber(input) or 300
  local newVal = pct / 100.0
  if _talentBuffAddrs.fight then writeFloat(_talentBuffAddrs.fight, newVal) end
  if _talentBuffAddrs.book then writeFloat(_talentBuffAddrs.book, newVal) end
  print(string.format("[WuXueTianCai] Set fight=%.0f%% book=%.0f%%", pct, pct))
end
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
if _talentBuffAddrs then
  if _talentBuffAddrs.fight and _talentBuffOrigFight then writeFloat(_talentBuffAddrs.fight, _talentBuffOrigFight) end
  if _talentBuffAddrs.book and _talentBuffOrigBook then writeFloat(_talentBuffAddrs.book, _talentBuffOrigBook) end
  print("[WuXueTianCai] Restored original values")
  _talentBuffAddrs = nil
end
{$asm}
              </AssemblerScript>
            </CheatEntry>
