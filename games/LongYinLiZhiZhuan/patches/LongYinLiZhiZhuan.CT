[DISABLE]
{$lua}
if syntaxcheck then return end
if _maxWeightOrig then
  local function getHero()
    LaunchMonoDataCollector()
    local gcId = mono_findClass("", "GameController")
    if not gcId or gcId == 0 then return nil end
    local fields = mono_class_enumFields(gcId)
    local inst
    for _, f in ipairs(fields) do if f.name == "_instance" then inst = mono_class_getStaticFieldValue(gcId, f.field) break end end
    if not inst or inst == 0 then return nil end
    local wd = readQword(inst + 0x20); if not wd or wd == 0 then return nil end
    local hl = readQword(wd + 0x50);  if not hl or hl == 0 then return nil end
    local ip = readQword(hl + 0x10);  if not ip or ip == 0 then return nil end
    local h = readQword(ip + 0x20);   if not h or h == 0 then return nil end
    return h
  end
  local hero = getHero()
  if hero then
    local itemListData = readQword(hero + 0x220)
    if itemListData and itemListData ~= 0 then
      writeFloat(itemListData + 0x20, _maxWeightOrig)
    end
  end
  print(string.format("[Weight] Restored to %.0f", _maxWeightOrig))
  _maxWeightOrig = nil
end
{$asm}
