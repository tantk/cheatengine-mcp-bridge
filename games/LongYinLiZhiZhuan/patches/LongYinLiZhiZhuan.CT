for i = 0, 5 do cmbML.Items.add(tostring(i)) end; cmbML.ItemIndex = 5
local btnMat = createButton(frm); btnMat.Left = 400; btnMat.Top = Y - 2; btnMat.Width = 100; btnMat.Height = 24
btnMat.Caption = "Add Material"
