<?xml version="1.0" encoding="utf-8"?>
<CheatTable>
  <CheatEntries>
    <CheatEntry>
      <ID>0</ID>
      <Description>"LongYinLiZhiZhuan (v1.0) - Attach to game first, then enable cheats"</Description>
      <GroupHeader>1</GroupHeader>
      <Color>FF0000</Color>
      <CheatEntries>

        <CheatEntry>
          <ID>10</ID>
          <Description>"--- Resources ---"</Description>
          <GroupHeader>1</GroupHeader>
          <Color>008000</Color>
          <CheatEntries>
            <CheatEntry>
              <ID>700</ID>
              <Description>"Set Money (Silver)"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
LaunchMonoDataCollector()
local gcId = mono_findClass("", "GameController")
local fields = mono_class_enumFields(gcId)
local gcInstance = nil
for _, f in ipairs(fields) do
  if f.name == "_instance" then
    gcInstance = mono_class_getStaticFieldValue(gcId, f.field)
    break
  end
end
if not gcInstance or gcInstance == 0 then error("GameController not found") end
local worldData = readQword(gcInstance + 0x20)
local herosList = readQword(worldData + 0x50)
local itemsPtr = readQword(herosList + 0x10)
local hero = readQword(itemsPtr + 0x20)
if not hero or hero == 0 then error("Hero not found") end
local itemListData = readQword(hero + 0x220)
if not itemListData or itemListData == 0 then error("ItemListData not found") end
local cur = readInteger(itemListData + 0x18)
local input = InputQuery("Set Money", "Current: " .. cur .. " silver. Enter new value:", "9999")
if input then
  local val = tonumber(input) or 9999
  writeInteger(itemListData + 0x18, math.floor(val))
  print(string.format("[Money] Set to %d silver", val))
end
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
print("[Money] (value remains as set)")
{$asm}
              </AssemblerScript>
            </CheatEntry>
            <CheatEntry>
              <ID>1200</ID>
              <Description>"Max Carry Weight (no inventory limit)"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
LaunchMonoDataCollector()
local gcId = mono_findClass("", "GameController")
local fields = mono_class_enumFields(gcId)
local gcInstance = nil
for _, f in ipairs(fields) do
  if f.name == "_instance" then
    gcInstance = mono_class_getStaticFieldValue(gcId, f.field)
    break
  end
end
if not gcInstance or gcInstance == 0 then error("GameController not found") end
local worldData = readQword(gcInstance + 0x20)
local herosList = readQword(worldData + 0x50)
local itemsPtr = readQword(herosList + 0x10)
local hero = readQword(itemsPtr + 0x20)
if not hero or hero == 0 then error("Hero not found") end
local itemListData = readQword(hero + 0x220)
if not itemListData or itemListData == 0 then error("ItemListData not found") end
local curMax = readFloat(itemListData + 0x20)
maxWeightOrig = curMax
writeFloat(itemListData + 0x20, 99999.0)
print(string.format("[Weight] Max carry weight: %.0f -> 99999", curMax))
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
if maxWeightOrig then
  local gcId = mono_findClass("", "GameController")
  local fields = mono_class_enumFields(gcId)
  local gcInstance = nil
  for _, f in ipairs(fields) do
    if f.name == "_instance" then
      gcInstance = mono_class_getStaticFieldValue(gcId, f.field)
      break
    end
  end
  if gcInstance and gcInstance ~= 0 then
    local worldData = readQword(gcInstance + 0x20)
    local herosList = readQword(worldData + 0x50)
    local itemsPtr = readQword(herosList + 0x10)
    local hero = readQword(itemsPtr + 0x20)
    if hero and hero ~= 0 then
      local itemListData = readQword(hero + 0x220)
      if itemListData and itemListData ~= 0 then
        writeFloat(itemListData + 0x20, maxWeightOrig)
      end
    end
  end
  print(string.format("[Weight] Restored to %.0f", maxWeightOrig))
  maxWeightOrig = nil
end
{$asm}
              </AssemblerScript>
            </CheatEntry>
            <CheatEntry>
              <ID>1300</ID>
              <Description>"Max Rarity All Inventory Items"</Description>
              <Color>000000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>
[ENABLE]
{$lua}
if syntaxcheck then return end
LaunchMonoDataCollector()
local gcId = mono_findClass("", "GameController")
local fields = mono_class_enumFields(gcId)
local gcInstance = nil
for _, f in ipairs(fields) do
  if f.name == "_instance" then
    gcInstance = mono_class_getStaticFieldValue(gcId, f.field)
    break
  end
end
if not gcInstance or gcInstance == 0 then error("GameController not found") end
local worldData = readQword(gcInstance + 0x20)
local herosList = readQword(worldData + 0x50)
local itemsPtr = readQword(herosList + 0x10)
local hero = readQword(itemsPtr + 0x20)
if not hero or hero == 0 then error("Hero not found") end
local itemListData = readQword(hero + 0x220)
if not itemListData or itemListData == 0 then error("ItemListData not found") end
local allItem = readQword(itemListData + 0x28)
local itemCount = readInteger(allItem + 0x18)
local itemArr = readQword(allItem + 0x10)
local changed = 0
for i = 0, itemCount - 1 do
  local item = readQword(itemArr + 0x20 + i * 8)
  if item and item ~= 0 then
    local cur = readInteger(item + 0x40)
    if cur ~= 5 then
      writeInteger(item + 0x40, 5)
      changed = changed + 1
    end
  end
end
print(string.format("[Rarity] Set %d/%d items to max rarity (5)", changed, itemCount))
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
print("[Rarity] (values remain as set)")
{$asm}
